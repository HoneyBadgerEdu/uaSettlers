---
import Layout from "../layouts/Layout.astro";
import Link from "../components/Link.astro";
import { getCollection } from "astro:content";

interface Item {
  name: string;
  description: string;
  url: string;
  isExternal: boolean;
}

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout>
  <main class="[&_p]:text-muted-foreground">
    <h2>Про проект</h2>
    <p>
      Що очікувати при прибутті в іншу країну, інтеграційна програма, грошове забеспечення,
      перехід на інший статус.
    </p>
    <h2>Країни</h2>
    <div class="flex flex-col gap-2">
      {
        posts.map((post) => (
          <a
            class="hover:bg-muted -mx-3 flex flex-col rounded-md px-3 py-2 no-underline"
            href={`/blog/${post.id}`}
          >
            <span>{post.data.title}</span>
            <span class="text-muted-foreground">{post.data.description}</span>
          </a>
        ))
      }
    </div>
    <h2>More</h2>
    <p>
      Miniblog is open source under the MIT license, and is heavily inspired by
      Emil Kowalski's <Link url="https://emilkowal.ski/">personal website</Link> which
      is built in Next.js.
    </p>
  </main>
</Layout>
